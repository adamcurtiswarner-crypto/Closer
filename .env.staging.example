# Staging Environment — points to a separate Firebase project
# Copy this to .env.staging and fill in your staging project values
# To use: APP_ENV=staging npx expo start

EXPO_PUBLIC_FIREBASE_API_KEY=your_staging_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=stoke-staging.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=stoke-staging
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=stoke-staging.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_staging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_staging_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-your_staging_measurement_id

EXPO_PUBLIC_SENTRY_DSN=your_staging_sentry_dsn

# RevenueCat (use sandbox keys for staging)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your_staging_revenuecat_key
