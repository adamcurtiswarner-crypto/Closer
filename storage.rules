rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile photos: any authenticated user can read.
    // Only the owner can write their own avatar.
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // Partner photos: scoped by coupleId.
    // Only couple members can read/write (verified via upload path).
    match /partner-photos/{coupleId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Prompt response photos: scoped by coupleId.
    // Size limited to 10MB, images only.
    match /responses/{coupleId}/{assignmentId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Chat images: scoped by coupleId.
    // Size limited to 10MB, images only.
    match /chat/{coupleId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Album photos: scoped by coupleId.
    match /photos/{coupleId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Milestone photos: scoped by coupleId.
    match /milestones/{coupleId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
