rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isCoupleMember(coupleId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.member_ids;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.is_admin == true;
    }

    // ============================================
    // USERS
    // ============================================

    match /users/{userId} {
      // Owner always; partners in the same couple can read each other's
      // profile (love language, photo, display name — product intent).
      // Membership is validated against the couple doc's member_ids.
      allow read: if isOwner(userId) ||
        (resource.data.couple_id != null && isCoupleMember(resource.data.couple_id));
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Soft delete only
    }

    // ============================================
    // COUPLES
    // ============================================

    match /couples/{coupleId} {
      // Members can read; pending couples readable for invite acceptance
      allow read: if isCoupleMember(coupleId) ||
        (isAuthenticated() && resource.data.status == 'pending');
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.member_ids;
      // Members can update; non-members can join a pending couple
      allow update: if isCoupleMember(coupleId) ||
        (isAuthenticated() &&
         resource.data.status == 'pending' &&
         request.resource.data.status == 'active' &&
         request.auth.uid in request.resource.data.member_ids);
      allow delete: if false;
    }

    // ============================================
    // PRESENCE
    // ============================================

    match /presence/{coupleId}/members/{memberId} {
      // Read: couple members can see each other's presence
      allow read: if isCoupleMember(coupleId);
      // Write: only the user themselves can update their own presence
      allow create, update: if isOwner(memberId) && isCoupleMember(coupleId);
      allow delete: if false;
    }

    // ============================================
    // CHAT MESSAGES
    // ============================================

    match /couples/{coupleId}/messages/{messageId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId) &&
        request.resource.data.sender_id == request.auth.uid;
      // Only sender can soft-delete (update is_deleted + clear text)
      allow update: if isCoupleMember(coupleId) &&
        resource.data.sender_id == request.auth.uid;
      allow delete: if false;
    }

    // ============================================
    // CHAT READ CURSORS
    // ============================================

    match /couples/{coupleId}/chat_read_cursors/{userId} {
      allow read: if isCoupleMember(coupleId);
      allow create, update: if isOwner(userId) && isCoupleMember(coupleId);
      allow delete: if false;
    }

    // ============================================
    // CHECK-INS — private per user, only the user who created can read their own
    // ============================================

    match /couples/{coupleId}/check_ins/{checkInId} {
      allow read: if isCoupleMember(coupleId) && resource.data.user_id == request.auth.uid;
      allow create: if isCoupleMember(coupleId) && request.resource.data.user_id == request.auth.uid;
    }

    // ============================================
    // SPARKS — couple members can read/write
    // ============================================

    match /couples/{coupleId}/sparks/{sparkId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId) &&
        request.resource.data.sender_id == request.auth.uid;
      allow update: if isCoupleMember(coupleId);
      allow delete: if false;
    }

    // ============================================
    // REFLECTIONS — couple members can read/write
    // ============================================

    match /couples/{coupleId}/reflections/{reflectionId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId) &&
        request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // MISSIONS — couple members can read/write
    // ============================================

    match /couples/{coupleId}/missions/{missionId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId) &&
        request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // PULSE SCORES — couple members can read, only functions write
    // ============================================

    match /couples/{coupleId}/pulse_scores/{weekId} {
      allow read: if isCoupleMember(coupleId);
    }

    // ============================================
    // COACHING INSIGHTS — couple members can read and update (dismiss/acted_on), only functions create
    // ============================================

    match /couples/{coupleId}/coaching_insights/{weekId} {
      allow read: if isCoupleMember(coupleId);
      allow update: if isCoupleMember(coupleId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissed_at', 'acted_on']);
    }

    // ============================================
    // GOALS
    // ============================================

    match /couples/{coupleId}/goals/{goalId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId);
      allow update: if isCoupleMember(coupleId);
      allow delete: if false; // Soft delete via archived status
    }

    match /couples/{coupleId}/goals/{goalId}/completions/{completionId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId);
      // Delete allowed for toggling off a completion
      allow delete: if isCoupleMember(coupleId);
      allow update: if false;
    }

    // ============================================
    // WISHLIST ITEMS
    // ============================================

    match /couples/{coupleId}/wishlist_items/{itemId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId);
      allow update: if isCoupleMember(coupleId);
      allow delete: if false; // Soft delete via is_deleted field
    }

    // ============================================
    // DATE NIGHTS
    // ============================================

    match /couples/{coupleId}/date_nights/{dateNightId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId);
      allow update: if isCoupleMember(coupleId);
      allow delete: if false;
    }

    // ============================================
    // COUPLE INVITES
    // ============================================

    match /couple_invites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.inviter_id == request.auth.uid;
      // Inviter can update their own invite (cancel)
      // Non-inviter can only accept a pending invite
      allow update: if isAuthenticated() &&
        (resource.data.inviter_id == request.auth.uid ||
         (resource.data.status == 'pending' &&
          request.auth.uid != resource.data.inviter_id &&
          request.resource.data.status == 'accepted'));
      allow delete: if false;
    }

    // ============================================
    // PROMPTS (Admin only for write)
    // ============================================

    match /prompts/{promptId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // FOLLOW-UP TEMPLATES (Admin only for write)
    // ============================================

    match /follow_up_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // PROMPT ASSIGNMENTS
    // ============================================

    match /prompt_assignments/{assignmentId} {
      allow read: if isAuthenticated() &&
        isCoupleMember(resource.data.couple_id);
      // Cloud Functions create daily assignments; clients can create explore assignments
      allow create: if isAuthenticated() &&
        isCoupleMember(request.resource.data.couple_id) &&
        request.resource.data.source == 'explore';
      allow update: if isCoupleMember(resource.data.couple_id);
      allow delete: if false;
    }

    // ============================================
    // PROMPT RESPONSES
    // ============================================

    match /prompt_responses/{responseId} {
      // Can read if in same couple
      allow read: if isAuthenticated() &&
        isCoupleMember(resource.data.couple_id);

      // Can create own response
      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.user_id) &&
        isCoupleMember(request.resource.data.couple_id);

      // Can update own response (draft edits OR feedback on submitted)
      allow update: if isAuthenticated() &&
        isOwner(resource.data.user_id);

      allow delete: if false;
    }

    // ============================================
    // PROMPT COMPLETIONS
    // ============================================

    match /prompt_completions/{completionId} {
      // Hearth "we talked" mark: the update is confined to the `discussed`
      // map, the writer only touches their OWN uid key, no existing keys are
      // removed, and the written value is serverTimestamp() (== request.time).
      //
      // Rule-language limits (documented intentionally):
      // - We cannot require the doc's `signal` to be repair/divergence here
      //   without brittle field checks; the server initializes `discussed`
      //   only for those signals, and this rule requires the field to
      //   already exist, which closes that gap in practice.
      // - We cannot prevent a member re-writing their own key's timestamp
      //   (MapDiff cannot distinguish add from modify), but the value is
      //   still forced to request.time, so it stays an honest "marked at".
      function isDiscussedOnlyMark() {
        return request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['discussed']) &&
          ('discussed' in resource.data) &&
          request.resource.data.discussed is map &&
          // Only the writer's own key may change…
          request.resource.data.discussed.diff(resource.data.discussed)
            .affectedKeys().hasOnly([request.auth.uid]) &&
          // …and every previously present key must be retained.
          request.resource.data.discussed.keys()
            .hasAll(resource.data.discussed.keys()) &&
          // The writer's key must be present and be serverTimestamp().
          (request.auth.uid in request.resource.data.discussed) &&
          request.resource.data.discussed[request.auth.uid] == request.time;
      }

      // Legacy client writes: reactions (own-key toggle) and memory saves.
      function isLegacyCompletionUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'updated_at', 'is_memory_saved']);
      }

      allow read: if isAuthenticated() &&
        isCoupleMember(resource.data.couple_id);
      // Created by Cloud Functions only
      allow create: if false;
      // Couple members may only make field-scoped updates: the Hearth
      // "we talked" mark or the pre-existing reaction/memory-save writes.
      allow update: if isCoupleMember(resource.data.couple_id) &&
        (isDiscussedOnlyMark() || isLegacyCompletionUpdate());
      allow delete: if false;
    }

    // ============================================
    // MEMORY ARTIFACTS
    // ============================================

    match /memory_artifacts/{memoryId} {
      allow read: if isAuthenticated() &&
        isCoupleMember(resource.data.couple_id);

      allow create: if isAuthenticated() &&
        isCoupleMember(request.resource.data.couple_id);

      allow update: if isAuthenticated() &&
        isCoupleMember(resource.data.couple_id);

      allow delete: if false; // Soft delete only
    }

    // ============================================
    // EVENTS (Analytics)
    // ============================================

    match /events/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================
    // EXPERIMENTS
    // ============================================

    match /experiments/{experimentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // SUBSCRIPTIONS
    // ============================================

    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() &&
        (isOwner(resource.data.user_id) ||
         ('couple_id' in resource.data && resource.data.couple_id != null && isCoupleMember(resource.data.couple_id)));
      allow write: if false; // Managed by Cloud Functions
    }

    // ============================================
    // ADMINS
    // ============================================

    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if false; // Manual setup only
    }
  }
}
